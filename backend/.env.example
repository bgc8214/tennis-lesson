# === 앱 기본 ===
APP_ENV=development
APP_NAME=tennis-lesson-api
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# === CORS ===
CORS_ALLOW_ORIGINS=http://localhost:3000

# === Supabase ===
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=super-long-jwt-secret

# === Google Gemini (무료 티어) ===
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TEMPERATURE=0.4

# === Whisper (로컬 추론) ===
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=ko

# === STT 프로바이더 ===
# local: faster-whisper 로컬 추론 (무료, CPU에서 느림 — 로컬/GPU 환경 권장)
# groq : Groq 호스티드 whisper-large-v3-turbo ($0.04/오디오시간 — Cloud Run 권장)
STT_PROVIDER=local
GROQ_API_KEY=gsk_...
GROQ_STT_MODEL=whisper-large-v3-turbo

# === 인용 검증 (할루시네이션 게이트) ===
# LLM 인용 vs STT 전사 원문 fuzzy match 통과 임계값 (0.0~1.0, 높을수록 엄격)
VERIFY_MATCH_THRESHOLD=0.75

# === yt-dlp ===
YTDLP_FORMAT=bestaudio/best
YTDLP_MAX_DURATION_SEC=5400
# Cloud Run 등 데이터센터 IP에서 YouTube 봇 감지 우회용 residential proxy URL (선택)
# 예: YTDLP_PROXY=http://user:pass@gate.residential-proxy.example:7777
YTDLP_PROXY=

# === 분석 파이프라인 ===
ANALYZE_TIMEOUT_SEC=600
TRANSCRIPT_PREFERRED_LANGUAGES=ko,ko-KR,en
# whisper(기본): STT 전사 → Gemini 구조화 → 코드 레벨 인용 검증 (할루시네이션 최소)
# gemini: 오디오 청크를 Gemini가 직접 듣고 추출 (폴백)
# gemini-youtube: YouTube URL을 Gemini에 직접 전달 (yt-dlp 미사용, 할루시네이션 큼)
TRANSCRIPT_ENGINE=whisper
